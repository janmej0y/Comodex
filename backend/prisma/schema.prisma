generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  STORE_KEEPER
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RECEIPT
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
}

enum TransferStatus {
  PENDING
  COMPLETED
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String
  passwordHash     String
  role             Role
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  refreshTokens    RefreshToken[]
  auditEvents      AuditEvent[]
  purchaseOrders   PurchaseOrder[] @relation("PurchaseOrdersCreatedBy")
  goodsReceipts    GoodsReceipt[]  @relation("ReceiptsReceivedBy")
  stockLedger      StockLedger[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Warehouse {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  city            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  balances        InventoryBalance[]
  stockLedger     StockLedger[]
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]
  alertRules      AlertRule[]
  outgoingTransfers StockTransfer[] @relation("TransferFromWarehouse")
  incomingTransfers StockTransfer[] @relation("TransferToWarehouse")
}

model Product {
  id              String             @id
  name            String
  category        String
  imageUrl        String?
  unitPrice       Float
  quantity        Int                @default(0)
  reorderLevel    Int                @default(40)
  updatedAt       DateTime           @updatedAt
  balances        InventoryBalance[]
  stockLedger     StockLedger[]
  transfers       StockTransfer[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines GoodsReceiptLine[]
  alertRules      AlertRule[]
}

model InventoryBalance {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
}

model StockLedger {
  id             String       @id @default(cuid())
  productId      String
  warehouseId    String?
  movementType   MovementType
  quantityDelta  Int
  quantityAfter  Int
  reason         String
  referenceType  String
  referenceId    String?
  createdAt      DateTime     @default(now())
  createdById    String?
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([warehouseId, createdAt])
}

model StockTransfer {
  id              String         @id @default(cuid())
  reference       String         @unique
  productId       String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Int
  status          TransferStatus @default(COMPLETED)
  createdAt       DateTime       @default(now())
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse   Warehouse      @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse      @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  reference     String              @unique
  supplier      String
  status        PurchaseOrderStatus @default(DRAFT)
  warehouseId   String
  orderedById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  warehouse     Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  orderedBy     User                @relation("PurchaseOrdersCreatedBy", fields: [orderedById], references: [id], onDelete: Restrict)
  lines         PurchaseOrderLine[]
  receipts      GoodsReceipt[]
}

model PurchaseOrderLine {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantityOrdered  Int
  quantityReceived Int           @default(0)
  unitPrice        Float
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  reference       String             @unique
  purchaseOrderId String
  warehouseId     String
  receivedById    String
  notes           String?
  createdAt       DateTime           @default(now())
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  receivedBy      User               @relation("ReceiptsReceivedBy", fields: [receivedById], references: [id], onDelete: Restrict)
  lines           GoodsReceiptLine[]
}

model GoodsReceiptLine {
  id             String       @id @default(cuid())
  goodsReceiptId String
  productId      String
  quantity       Int
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model AlertRule {
  id           String     @id @default(cuid())
  name         String
  threshold    Int
  channel      String
  isActive     Boolean    @default(true)
  warehouseId  String?
  productId    String?
  createdAt    DateTime   @default(now())
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model AuditEvent {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
}

